generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Area {
  BACK_BAY
  EVERETT
  MALDEN
  ALLSTON
  CAMBRIDGE
  SOMERVILLE
  BROOKLINE
}

enum LayoutType {
  STUDIO
  ONE_BED_ONE_BATH
  TWO_BED_TWO_BATH
  THREE_BED_TWO_BATH
}

enum PetPolicy {
  OPEN
  CATS_ONLY
  CATS_AND_DOGS
}

model Property {
  id               String       @id @default(cuid())
  slug             String       @unique
  name             String
  address          String
  area             Area
  isPublished      Boolean      @default(true)
  petPolicy        PetPolicy
  acceptsUndergrad Boolean      @default(true)
  parkingFee       Int?
  promotions       String?
  nearbySchools    String[]     @default([])
  imageUrls        String[]
  videoUrls        String[]     @default([])
  description      String       @db.Text
  transitInfo      String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  floorPlans       FloorPlan[]

  @@index([area])
  @@index([createdAt])
}

model FloorPlan {
  id           String     @id @default(cuid())
  name         String
  propertyId   String
  property     Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  layout       LayoutType
  monthlyRent  Int
  roomSizeSqFt Int?
  hasBrokerFee Boolean    @default(false)
  isFurnished  Boolean    @default(false)
  imageUrls    String[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([monthlyRent])
  @@index([propertyId])
}
